rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if false;
    }

    match /companies/{uid} {
      allow read:   if isOwner(uid) || isAdmin()
                    || (isSignedIn() && resource != null && resource.data.status == "active");
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if false;
    }

    match /pagos/{pagoId} {
      allow read:   if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /admins/{uid} {
      allow read:   if isOwner(uid);
      allow write:  if false;
    }

    match /catalogos/{catId} {
      allow read:   if isSignedIn() &&
                    (resource.data.uid == request.auth.uid
                     || (resource.data.visible == true)
                     || isAdmin());
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /representantes/{repId} {
      allow read:   if isSignedIn() &&
                    (resource.data.uid == request.auth.uid
                     || (resource.data.visible == true)
                     || isAdmin());
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /galeriaFotos/{fotoId} {
      allow read:   if isSignedIn() &&
                    (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /galeriaVideos/{videoId} {
      allow read:   if isSignedIn() &&
                    (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /categoriasAgtech/{catId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /noticias/{noticiaId} {
      allow read:   if isSignedIn() &&
                    (resource.data.estado == 'publicado' || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
